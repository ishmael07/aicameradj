{
  "name": "aicameradj",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Camera-controlled DJ — mix two decks with your hands on a live glassmorphism deck.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "setup:model": "mkdir -p public/models && curl -L -o public/models/hand_landmarker.task https://storage.googleapis.com/mediapipe-models/hand_landmarker/hand_landmarker/float16/latest/hand_landmarker.task"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "0.10.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "web-audio-beat-detector": "^8.2.37",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
