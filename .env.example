# Copy to ".env" and fill in to enable optional sources.
# Audius + Local file upload work with NO config.

# Jamendo (optional): free Creative Commons catalog, fully mixable.
# Get a free client id at https://developer.jamendo.com → create an app.
VITE_JAMENDO_CLIENT_ID=

# SoundCloud (optional, advanced): requires a backend proxy that holds
# SoundCloud Artist Pro API credentials and re-streams CORS-clean audio.
# Without this, SoundCloud appears in the UI but is disabled.
VITE_SOUNDCLOUD_PROXY_URL=
